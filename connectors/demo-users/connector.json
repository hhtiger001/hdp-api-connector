{
  "apiVersion": "hdp.connector/v1alpha1",
  "metadata": {
    "name": "demo-users",
    "displayName": "Demo Users"
  },
  "connectionSpec": {
    "type": "object",
    "required": [ "base_url", "api_key" ],
    "properties": {
      "base_url": {
        "type": "string",
        "title": "Base URL"
      },
      "api_key": {
        "type": "string",
        "title": "API Key",
        "secret": true
      }
    }
  },
  "request": {
    "baseUrl": "{{ config['base_url'] }}",
    "auth": {
      "type": "apiKey",
      "in": "header",
      "name": "X-API-Key",
      "value": "{{ config['api_key'] }}"
    }
  },
  "tools": [ {
    "name": "users",
    "title": "List users",
    "description": "List demo users.",
    "endpointRef": "endpoints/users.json"
  } ]
}

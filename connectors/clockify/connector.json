{
  "apiVersion" : "hdp.connector/v1alpha1",
  "metadata" : {
    "name" : "clockify-manifest",
    "displayName" : "clockify-manifest"
  },
  "connectionSpec" : {
    "type" : "object",
    "$schema" : "http://json-schema.org/draft-07/schema#",
    "required" : [ "api_key", "workspace_id" ],
    "properties" : {
      "api_key" : {
        "type" : "string",
        "title" : "API Key",
        "description" : "You can get your api access_key <a href=\"https://app.clockify.me/user/settings\">here</a> This API is Case Sensitive.",
        "order" : 0,
        "secret" : true
      },
      "api_url" : {
        "type" : "string",
        "title" : "API Url",
        "description" : "The URL for the Clockify API. This should only need to be modified if connecting to an enterprise version of Clockify.",
        "default" : "https://api.clockify.me",
        "order" : 1
      },
      "workspace_id" : {
        "type" : "string",
        "title" : "Workspace Id",
        "description" : "WorkSpace Id",
        "order" : 2
      }
    },
    "additionalProperties" : true
  },
  "request" : {
    "baseUrl" : "https://api.clockify.me/api/v1/",
    "auth" : {
      "type" : "apiKey",
      "in" : "header",
      "name" : "X-Api-Key",
      "value" : "{{ config['api_key'] }}"
    }
  },
  "tools" : [ {
    "name" : "users",
    "title" : "Users",
    "endpointRef" : "endpoints/users.json"
  }, {
    "name" : "projects",
    "title" : "Projects",
    "endpointRef" : "endpoints/projects.json"
  }, {
    "name" : "clients",
    "title" : "Clients",
    "endpointRef" : "endpoints/clients.json"
  }, {
    "name" : "tags",
    "title" : "Tags",
    "endpointRef" : "endpoints/tags.json"
  }, {
    "name" : "user_groups",
    "title" : "User Groups",
    "endpointRef" : "endpoints/user-groups.json"
  }, {
    "name" : "time_entries",
    "title" : "Time Entries",
    "endpointRef" : "endpoints/time-entries.json"
  }, {
    "name" : "tasks",
    "title" : "Tasks",
    "endpointRef" : "endpoints/tasks.json"
  } ]
}